{
    "chat.tools.terminal.autoApprove": {
        "ForEach-Object": true,
        "npm.cmd": true,
        "/^cmd /c npm run test$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^cmd\\.exe /c npm run test$/": {
            "approve": true,
            "matchCommandLine": true
        }
    }
}